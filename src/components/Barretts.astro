---
import siteData from '../data/site.json';

const { barretts } = siteData;
---

<section id="barretts" class="section-padding bg-surface">
  <div class="container-narrow">
    <div class="reveal text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep sm:text-4xl">{barretts.title}</h2>
      <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-primary"></div>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-2">
      <article class="reveal rounded-2xl border border-surface-dark bg-white p-8 shadow-card">
        <h3 class="font-display text-xl font-semibold text-deep">{barretts.conditionTitle}</h3>
        <ul class="mt-6 space-y-3">
          {
            barretts.conditionPoints.map((point) => (
              <li class="flex gap-3 text-sm leading-relaxed text-muted">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-highlight" aria-hidden="true"></span>
                {point}
              </li>
            ))
          }
        </ul>
      </article>

      <article class="reveal reveal-delay-1 rounded-2xl border border-primary/20 bg-deep p-8 text-white shadow-card">
        <h3 class="font-display text-xl font-semibold">{barretts.solutionTitle}</h3>
        <ul class="mt-6 space-y-3">
          {
            barretts.solutionPoints.map((point) => (
              <li class="flex gap-3 text-sm leading-relaxed text-white/85">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white/15 text-xs" aria-hidden="true">✓</span>
                {point}
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </div>
</section>
