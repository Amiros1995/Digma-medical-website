---
import siteData from '../data/site.json';

const { market } = siteData;
---

<section id="market" class="section-padding bg-deep text-white">
  <div class="container-wide">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">{market.title}</h2>
      <p class="mt-4 text-lg text-white/75">{market.subtitle}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        market.stats.map((stat, i) => (
          <div
            class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 3)}` : ''} rounded-2xl border border-white/10 bg-white/5 p-6 text-center backdrop-blur-sm transition hover:-translate-y-1 hover:bg-white/10`}
          >
            <p class="font-display text-3xl font-bold text-white sm:text-4xl">{stat.value}</p>
            <p class="mt-2 font-semibold text-white/90">{stat.label}</p>
            <p class="mt-1 text-sm text-white/60">{stat.detail}</p>
          </div>
        ))
      }
    </div>

    <p class="reveal mx-auto mt-10 max-w-3xl text-center text-sm leading-relaxed text-white/65">
      {market.footnote}
    </p>
  </div>
</section>
