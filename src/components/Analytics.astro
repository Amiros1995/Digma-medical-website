---
import { siteConfig } from '../config/site';
---

{siteConfig.ga4MeasurementId && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.ga4MeasurementId}`}></script>
    <script is:inline define:vars={{ measurementId: siteConfig.ga4MeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', measurementId);
    </script>
  </>
)}
