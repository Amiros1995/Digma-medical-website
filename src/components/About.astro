---
import siteData from '../data/site.json';

const { about } = siteData;
---

<section id="about" class="section-padding bg-white">
  <div class="container-narrow">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep sm:text-4xl">{about.title}</h2>
      <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-highlight"></div>
    </div>

    <div class="reveal mt-12 grid gap-8 lg:grid-cols-2 lg:gap-12">
      <div class="space-y-5 text-base leading-relaxed text-muted">
        {about.paragraphs.slice(0, 2).map((p) => <p>{p}</p>)}
      </div>
      <div class="space-y-5 text-base leading-relaxed text-muted">
        {about.paragraphs.slice(2).map((p) => <p>{p}</p>)}
        <p class="rounded-xl border border-primary/15 bg-surface p-5 text-sm font-medium text-deep">
          {about.clinicalCta}
          <a href="#contact" class="ml-1 text-primary underline-offset-2 hover:underline">Contact us →</a>
        </p>
      </div>
    </div>
  </div>
</section>
