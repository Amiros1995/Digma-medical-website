---
import siteData from '../data/site.json';

const { technology } = siteData;
const base = import.meta.env.BASE_URL;
const consoleSrc = technology.image ? `${base}${technology.image.replace(/^\//, '')}` : null;
const catheterSrc = technology.secondaryImage
  ? `${base}${technology.secondaryImage.replace(/^\//, '')}`
  : null;

const icons = [
  'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z',
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5',
  'M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5',
];
---

<section id="technology" class="section-padding bg-white">
  <div class="container-wide">
    <div class="reveal mx-auto max-w-3xl text-center lg:mx-0 lg:max-w-2xl lg:text-left">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep sm:text-4xl">{technology.title}</h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">{technology.subtitle}</p>
      <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-highlight lg:mx-0"></div>
      {
        technology.imageCaption && (
          <p class="mt-6 text-base leading-relaxed text-muted">{technology.imageCaption}</p>
        )
      }
    </div>

    {
      (consoleSrc || catheterSrc) && (
        <div class="reveal mt-12 grid items-end gap-8 md:grid-cols-2 md:gap-10">
          {
            consoleSrc && (
              <figure class="flex flex-col items-center md:items-end">
                <img
                  src={consoleSrc}
                  alt={technology.imageAlt}
                  class="w-full max-w-md object-contain drop-shadow-lg sm:max-w-lg lg:max-w-xl"
                  loading="lazy"
                  width="800"
                  height="600"
                />
              </figure>
            )
          }
          {
            catheterSrc && (
              <figure class="flex flex-col items-center md:items-start">
                <img
                  src={catheterSrc}
                  alt={technology.secondaryImageAlt}
                  class="w-full max-w-md rounded-2xl object-contain shadow-card sm:max-w-lg"
                  loading="lazy"
                  width="800"
                  height="500"
                />
              </figure>
            )
          }
        </div>
      )
    }

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        technology.features.map((feature, i) => (
          <article class="reveal group rounded-2xl border border-surface-dark bg-surface/50 p-6 transition hover:-translate-y-1 hover:border-primary/30 hover:bg-white hover:shadow-card-hover">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary transition group-hover:bg-primary group-hover:text-white">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={icons[i % icons.length]}></path>
              </svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-deep">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{feature.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
