---
import siteData from '../data/site.json';
import { siteConfig } from '../config/site';

const { contact } = siteData;
const formspreeAction = siteConfig.formspreeId
  ? `https://formspree.io/f/${siteConfig.formspreeId}`
  : null;
---

<section id="contact" class="section-padding bg-surface">
  <div class="container-narrow">
    <div class="reveal mx-auto max-w-3xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep sm:text-4xl">{contact.title}</h2>
      <p class="mt-4 text-lg text-muted">{contact.subtitle}</p>
      <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-primary"></div>
    </div>

    <div class="reveal mt-12 mx-auto max-w-xl">
      {
        formspreeAction ? (
          <form action={formspreeAction} method="POST" class="space-y-5 rounded-2xl border border-surface-dark bg-white p-8 shadow-card">
            <div>
              <label for="name" class="mb-1.5 block text-sm font-medium text-deep">{contact.fields.name}</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full rounded-xl border border-surface-dark bg-surface/30 px-4 py-3 text-deep transition focus:border-primary focus:bg-white focus:outline-none"
              />
            </div>
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-deep">{contact.fields.email}</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full rounded-xl border border-surface-dark bg-surface/30 px-4 py-3 text-deep transition focus:border-primary focus:bg-white focus:outline-none"
              />
            </div>
            <div>
              <label for="subject" class="mb-1.5 block text-sm font-medium text-deep">{contact.fields.subject}</label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="w-full rounded-xl border border-surface-dark bg-surface/30 px-4 py-3 text-deep transition focus:border-primary focus:bg-white focus:outline-none"
              />
            </div>
            <div>
              <label for="message" class="mb-1.5 block text-sm font-medium text-deep">{contact.fields.message}</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full resize-y rounded-xl border border-surface-dark bg-surface/30 px-4 py-3 text-deep transition focus:border-primary focus:bg-white focus:outline-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full rounded-full bg-deep py-3.5 text-base font-semibold text-white transition hover:bg-primary"
            >
              {contact.submitLabel}
            </button>
          </form>
        ) : (
          <div class="rounded-2xl border border-surface-dark bg-white p-8 text-center shadow-card">
            <p class="text-muted">
              Contact form will be enabled once Formspree is configured. For now, please email us directly:
            </p>
            <a
              href={`mailto:${siteConfig.email}?subject=Digma%20Medical%20Inquiry`}
              class="mt-6 inline-flex items-center justify-center rounded-full bg-deep px-8 py-3.5 text-base font-semibold text-white transition hover:bg-primary"
            >
              {siteConfig.email}
            </a>
            <p class="mt-6 text-xs text-muted">
              To enable the form, add your Formspree ID in <code class="rounded bg-surface px-1.5 py-0.5">src/config/site.ts</code>
            </p>
          </div>
        )
      }
    </div>
  </div>
</section>
