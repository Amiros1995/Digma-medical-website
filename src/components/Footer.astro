---
import { siteConfig } from '../config/site';
---

<footer class="border-t border-surface-dark bg-deep text-white">
  <div class="section-padding !py-12">
    <div class="container-wide grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      <div>
        <div class="mb-4 flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/10 text-sm font-bold">D</span>
          <span class="font-display text-lg font-semibold">{siteConfig.name}</span>
        </div>
        <p class="max-w-sm text-sm leading-relaxed text-white/75">{siteConfig.tagline}</p>
      </div>

      <div>
        <h2 class="mb-3 font-display text-sm font-semibold uppercase tracking-wider text-white/60">Contact</h2>
        <a href={`mailto:${siteConfig.email}`} class="text-sm text-white/90 transition hover:text-white">
          {siteConfig.email}
        </a>
        <div class="mt-4">
          <a
            href={siteConfig.linkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-white/75 transition hover:text-white"
          >
            LinkedIn
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <div class="md:col-span-2 lg:col-span-1">
        <p class="rounded-xl border border-white/10 bg-white/5 p-4 text-xs leading-relaxed text-white/70">
          {siteConfig.iuoDisclaimer}
        </p>
      </div>
    </div>

    <div class="container-wide mt-10 border-t border-white/10 pt-6 text-center text-xs text-white/50">
      © {siteConfig.copyrightYear} {siteConfig.name}, Ltd. All rights reserved.
    </div>
  </div>
</footer>
